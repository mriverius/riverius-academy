---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="¿Qué curso me conviene? — Riverius Academy"
  description="Responde 6 preguntas rápidas y descubre cuál curso de IA es el ideal para ti: Automatizaciones con Make.com, Agentes IA con N8N o Copilot Studio."
>
  <section class="quiz-hero has-ambient">
    <div class="ambient" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="eyebrow">Test rápido</p>
      <h1 class="section-title">
        Descubre <span class="gradient-text">tu curso ideal</span>
      </h1>
      <p class="section-intro">
        6 preguntas, menos de un minuto. Al final te digo con cuál de los tres cursos deberías
        empezar según tu perfil.
      </p>
    </div>
  </section>

  <section class="section quiz-section">
    <div class="container">
      <div class="quiz glass" id="quiz">
        <!-- Progreso -->
        <div class="quiz-top">
          <span class="quiz-step" id="quiz-step">Pregunta 1 de 6</span>
          <div class="quiz-bar" role="progressbar" aria-label="Progreso del test">
            <div class="quiz-fill" id="quiz-fill"></div>
          </div>
        </div>

        <!-- Pregunta activa (la llena el script) -->
        <div class="quiz-body" id="quiz-body"></div>

        <!-- Navegación -->
        <div class="quiz-nav" id="quiz-nav">
          <button type="button" class="nav-btn" id="quiz-back" hidden>← Anterior</button>
          <button type="button" class="nav-btn nav-next" id="quiz-next" hidden>Siguiente →</button>
        </div>

        <!-- Resultado -->
        <div class="quiz-result" id="quiz-result" hidden>
          <p class="result-chip" id="result-chip"></p>
          <h2>
            Tu mejor opción es
            <span class="gradient-text" id="result-name"></span>
          </h2>
          <p class="result-why" id="result-why"></p>

          <div class="result-actions">
            <a id="result-wa" href="#" target="_blank" rel="noopener noreferrer" class="wa-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
              </svg>
              Quiero más información
            </a>
            <button type="button" class="restart" id="quiz-restart">Repetir el test ↺</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* estilos del quiz */
  .quiz-hero {
    position: relative;
    padding-block: 48px 16px;
  }

  .quiz-hero .ambient {
    mask-image: linear-gradient(180deg, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, black 40%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }

  .hero-inner .section-intro {
    margin-inline: auto;
  }

  .quiz-section {
    padding-top: 32px;
  }

  .quiz {
    max-width: 720px;
    margin-inline: auto;
    padding: 36px;
    border-radius: 24px;
  }

  /* --- progreso --- */
  .quiz-top {
    margin-bottom: 28px;
  }

  .quiz-step {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .quiz-bar {
    margin-top: 10px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-border);
    overflow: hidden;
  }

  .quiz-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: var(--gradient-main);
    transition: width 0.5s var(--ease);
  }

  /* --- pregunta --- */
  .quiz-body :global(h2) {
    font-size: clamp(1.2rem, 2.4vw, 1.55rem);
    margin-bottom: 22px;
  }

  .quiz-body :global(.options) {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .quiz-body :global(.option) {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    text-align: left;
    padding: 16px 18px;
    border-radius: 14px;
    border: 1px solid var(--color-border);
    background: var(--glass-bg);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 0.98rem;
    cursor: pointer;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease),
      background-color 0.25s var(--ease);
  }

  .quiz-body :global(.option:hover) {
    border-color: var(--accent-cyan);
    transform: translateX(4px);
  }

  /* respuesta ya elegida (al volver atrás) */
  .quiz-body :global(.option.selected) {
    border-color: var(--accent-blue);
    background: rgb(37 99 235 / 0.08);
  }

  :global([data-theme='dark']) .quiz-body :global(.option.selected) {
    border-color: var(--accent-cyan);
    background: rgb(6 182 212 / 0.1);
  }

  .quiz-body :global(.option .key) {
    flex: none;
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 9px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent-blue);
    background: rgb(37 99 235 / 0.08);
    border: 1px solid rgb(37 99 235 / 0.25);
  }

  :global([data-theme='dark']) .quiz-body :global(.option .key) {
    color: var(--accent-cyan);
    background: rgb(6 182 212 / 0.1);
    border-color: rgb(6 182 212 / 0.3);
  }

  /* animación entre preguntas */
  .quiz-body :global(.q) {
    animation: q-in 0.4s var(--ease);
  }

  @keyframes q-in {
    from {
      opacity: 0;
      transform: translateX(16px);
    }
  }

  /* --- navegación --- */
  .quiz-nav {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-top: 24px;
    min-height: 24px;
  }

  /* display:flex le ganaría al atributo hidden sin esto */
  .quiz-nav[hidden] {
    display: none;
  }

  .nav-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    transition: color 0.2s ease;
  }

  .nav-btn:hover {
    color: var(--accent-cyan);
  }

  .nav-next {
    margin-left: auto;
    color: var(--accent-blue);
  }

  :global([data-theme='dark']) .nav-next {
    color: var(--accent-cyan);
  }

  /* --- resultado --- */
  .quiz-result {
    text-align: center;
    animation: q-in 0.5s var(--ease);
  }

  .result-chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-blue);
    background: rgb(37 99 235 / 0.08);
    border: 1px solid rgb(37 99 235 / 0.25);
    padding: 4px 14px;
    border-radius: 999px;
    margin-bottom: 16px;
  }

  :global([data-theme='dark']) .result-chip {
    color: var(--accent-cyan);
    background: rgb(6 182 212 / 0.1);
    border-color: rgb(6 182 212 / 0.3);
  }

  .quiz-result h2 {
    font-size: clamp(1.5rem, 3.4vw, 2.2rem);
  }

  .quiz-result h2 .gradient-text {
    display: block;
    margin-top: 4px;
  }

  .result-why {
    max-width: 520px;
    margin: 16px auto 0;
    font-size: 1rem;
  }

  .result-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  /* botón sobrio: gradiente de la marca en vez del verde de WhatsApp */
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 26px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    background: var(--gradient-main);
    background-size: 200% auto;
    box-shadow: 0 8px 24px rgb(37 99 235 / 0.3);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }

  .wa-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgb(139 92 246 / 0.4);
  }

  .restart {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    transition: color 0.2s ease;
  }

  .restart:hover {
    color: var(--accent-cyan);
  }

  @media (max-width: 600px) {
    .quiz {
      padding: 24px 20px;
    }
  }
</style>

<script>
  // ============================================================
  // Preguntas: cada opción suma puntos a make / n8n / copilot
  // ============================================================
  type Puntos = { make?: number; n8n?: number; copilot?: number };
  type Opcion = { texto: string; puntos: Puntos };

  const preguntas: { texto: string; opciones: Opcion[] }[] = [
    {
      texto: '¿Cuál es tu experiencia con herramientas de automatización?',
      opciones: [
        { texto: 'Ninguna — nunca he usado una', puntos: { make: 2 } },
        {
          texto: 'He probado alguna un par de veces (Zapier, Make o similares)',
          puntos: { make: 1, n8n: 1 },
        },
        {
          texto: 'Alta — domino este tipo de herramientas o tengo perfil técnico',
          puntos: { n8n: 2 },
        },
      ],
    },
    {
      texto: '¿Con qué herramientas trabajas todos los días?',
      opciones: [
        { texto: 'Gmail, Google Sheets y apps variadas', puntos: { make: 2 } },
        { texto: 'Microsoft 365: Teams, Outlook, SharePoint', puntos: { copilot: 3 } },
        { texto: 'Un poco de todo', puntos: { make: 1, n8n: 1 } },
      ],
    },
    {
      texto: '¿Qué quieres lograr primero?',
      opciones: [
        { texto: 'Automatizar las tareas repetitivas de mi día', puntos: { make: 2 } },
        { texto: 'Crear mi propio asistente que me ayude con mis tareas', puntos: { n8n: 3 } },
        { texto: 'Un asistente inteligente para mi equipo o empresa', puntos: { copilot: 2 } },
      ],
    },
    {
      texto: '¿Cómo trabajas?',
      opciones: [
        { texto: 'Por mi cuenta o con mi propio negocio', puntos: { make: 1, n8n: 1 } },
        { texto: 'En una empresa con herramientas corporativas', puntos: { copilot: 2 } },
        { texto: 'Freelance o agencia, con varios clientes', puntos: { n8n: 2 } },
      ],
    },
    {
      texto: '¿Qué tanto conocimiento técnico tienes? (conceptos como: API, HTTP, LLM…)',
      opciones: [
        { texto: 'Ninguno — esas siglas no me suenan', puntos: { make: 2 } },
        { texto: 'Me suenan, pero no las domino', puntos: { make: 1, copilot: 1 } },
        { texto: 'Sé qué son y me defiendo con lo técnico', puntos: { n8n: 2 } },
      ],
    },
    {
      texto: '¿Cuál describe mejor tu punto de partida hoy?',
      opciones: [
        { texto: 'Uso ChatGPT o Claude, nada más', puntos: { make: 2 } },
        { texto: 'Ya automatizo algo y quiero subir de nivel', puntos: { n8n: 2 } },
        { texto: 'Mi empresa quiere adoptar la IA en serio', puntos: { copilot: 2 } },
      ],
    },
  ];

  const cursos = {
    make: {
      nombre: 'Automatizaciones IA Make.com',
      curso: 'Make.com',
      nivel: 'Nivel 1 · Principiante',
      why: 'Es el punto de partida perfecto: automatizaciones visuales sin código, victorias rápidas desde la primera semana y la base ideal para después dar el salto a los agentes.',
    },
    n8n: {
      nombre: 'Agentes IA N8N',
      curso: 'N8N',
      nivel: 'Nivel 2 · Intermedio',
      why: 'Tu perfil pide más potencia: con N8N vas a construir tu propio asistente de IA — uno que razona, decide y ejecuta procesos completos por ti.',
    },
    copilot: {
      nombre: 'Agentes IA Copilot Studio',
      curso: 'Copilot Studio',
      nivel: 'Nivel 3 · Avanzado',
      why: 'Vives en el ecosistema Microsoft: con Copilot Studio vas a crear copilotos y chatbots integrados con Teams, Outlook y las herramientas que tu empresa ya usa.',
    },
  };

  const whatsapp = '50685973818';

  const body = document.getElementById('quiz-body')!;
  const result = document.getElementById('quiz-result')!;
  const stepEl = document.getElementById('quiz-step')!;
  const fillEl = document.getElementById('quiz-fill')!;
  const navEl = document.getElementById('quiz-nav')!;
  const backBtn = document.getElementById('quiz-back') as HTMLButtonElement;
  const nextBtn = document.getElementById('quiz-next') as HTMLButtonElement;

  let actual = 0;
  // respuestas guardadas: permite volver atrás y cambiar
  let respuestas: (number | null)[] = Array(preguntas.length).fill(null);
  let avance: ReturnType<typeof setTimeout> | undefined;

  function render() {
    const q = preguntas[actual]!;
    stepEl.textContent = `Pregunta ${actual + 1} de ${preguntas.length}`;
    fillEl.style.width = `${(actual / preguntas.length) * 100}%`;

    const letras = ['A', 'B', 'C'];
    body.innerHTML = `
      <div class="q">
        <h2>${q.texto}</h2>
        <div class="options">
          ${q.opciones
            .map(
              (o, i) => `
            <button type="button" class="option${respuestas[actual] === i ? ' selected' : ''}" data-i="${i}">
              <span class="key">${letras[i]}</span>
              ${o.texto}
            </button>`
            )
            .join('')}
        </div>
      </div>`;

    body.querySelectorAll<HTMLButtonElement>('.option').forEach((btn) =>
      btn.addEventListener('click', () => elegir(Number(btn.dataset.i)))
    );

    actualizarNav();
  }

  function actualizarNav() {
    backBtn.hidden = actual === 0;
    const respondida = respuestas[actual] !== null;
    nextBtn.hidden = !respondida;
    nextBtn.textContent = actual === preguntas.length - 1 ? 'Ver resultado →' : 'Siguiente →';
  }

  function elegir(i: number) {
    respuestas[actual] = i;
    // marca la selección y avanza tras una pausa breve
    body.querySelectorAll('.option').forEach((el, j) =>
      el.classList.toggle('selected', j === i)
    );
    actualizarNav();
    clearTimeout(avance);
    avance = setTimeout(avanzar, 350);
  }

  function avanzar() {
    clearTimeout(avance);
    if (respuestas[actual] === null) return;
    if (actual < preguntas.length - 1) {
      actual++;
      render();
    } else {
      mostrarResultado();
    }
  }

  function retroceder() {
    clearTimeout(avance);
    if (!result.hidden) {
      // volver del resultado a la última pregunta
      result.hidden = true;
      body.hidden = false;
      navEl.hidden = false;
      render();
      return;
    }
    if (actual > 0) {
      actual--;
      render();
    }
  }

  function ganador(): keyof typeof cursos {
    const s = { make: 0, n8n: 0, copilot: 0 };
    respuestas.forEach((r, i) => {
      if (r === null) return;
      for (const [k, v] of Object.entries(preguntas[i]!.opciones[r]!.puntos)) {
        s[k as keyof typeof s] += v ?? 0;
      }
    });

    const orden: (keyof typeof s)[] = ['make', 'n8n', 'copilot'];
    const max = Math.max(s.make, s.n8n, s.copilot);
    const empatados = orden.filter((k) => s[k] === max);

    // empate que incluye copilot + trabaja en Microsoft → copilot
    let win =
      empatados.length === 1
        ? empatados[0]!
        : empatados.includes('copilot') && respuestas[1] === 1
          ? 'copilot'
          : empatados[0]!;

    // principiante total (sin experiencia ni base técnica):
    // N8N le quedaría grande — que empiece por Make
    if (win === 'n8n' && respuestas[0] === 0 && respuestas[4] === 0) win = 'make';

    return win;
  }

  function mostrarResultado() {
    const curso = cursos[ganador()];

    stepEl.textContent = 'Resultado';
    fillEl.style.width = '100%';
    body.hidden = true;
    navEl.hidden = true;
    result.hidden = false;

    document.getElementById('result-chip')!.textContent = curso.nivel;
    document.getElementById('result-name')!.textContent = curso.nombre;
    document.getElementById('result-why')!.textContent = curso.why;

    const mensaje = `Mariano, hice la prueba de curso, y me salió que mi mejor opción es ${curso.curso}, quiero saber más información`;
    (document.getElementById('result-wa') as HTMLAnchorElement).href =
      `https://wa.me/${whatsapp}?text=${encodeURIComponent(mensaje)}`;
  }

  backBtn.addEventListener('click', retroceder);
  nextBtn.addEventListener('click', avanzar);

  document.getElementById('quiz-restart')!.addEventListener('click', () => {
    actual = 0;
    respuestas = Array(preguntas.length).fill(null);
    result.hidden = true;
    body.hidden = false;
    navEl.hidden = false;
    render();
  });

  render();
</script>
