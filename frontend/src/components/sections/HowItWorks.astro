---
// El ciclo semanal — iconos SVG personalizados (sin emojis)
const cycle = [
  {
    step: '01',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4.5" width="19" height="13" rx="3"/><path d="m10 8.5 5 3-5 3z" fill="currentColor" stroke="none"/><path d="M8 21h8"/></svg>`,
    title: 'La clase',
    text: 'Un video nuevo cada semana, disponible cuando quieras. Lo ves a tu ritmo — solo procura verlo antes de tu sesión, para que valga oro.',
  },
  {
    step: '02',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3.5H7a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8.5z"/><path d="M14 3.5v5h5M9 13l2 2 4-4"/></svg>`,
    title: 'Tu tarea',
    text: 'Cada clase termina con algo real que construir. Esa tarea es lo primero que revisamos juntos — nunca se queda sin retroalimentación.',
  },
  {
    step: '03',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8.5" r="3"/><path d="M2.5 19c.8-2.6 2.9-4 5.5-4s4.7 1.4 5.5 4"/><circle cx="17" cy="10" r="2.2"/><path d="M14.5 19c.5-1.9 1.4-2.8 2.5-3 1.9-.4 3.8.9 4.5 3"/></svg>`,
    title: 'Tu sesión en vivo conmigo',
    text: 'Cada semana, tú y yo, nadie más. Me muestras lo que armaste, aclaramos dudas y sales con tu siguiente paso claro.',
  },
];
---

<section id="como-funciona" class="section how has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container">
    <div class="head-row">
      <div class="reveal">
        <p class="eyebrow">Cómo funciona</p>
        <h2 class="section-title">
          Atención personalizada, <span class="gradient-text">a tu propio ritmo</span>
        </h2>
        <p class="section-intro">
          Nada de cursos grabados que nadie termina. Sigues un ciclo semanal simple, con un
          profesor contigo en cada paso.
        </p>
      </div>

      <!-- Chat de WhatsApp en vivo: acompañamiento real -->
      <figure class="wa-chat glass reveal" aria-hidden="true">
        <div class="wa-body">
          <div class="msg in">
            <p>Mariano, ¿cómo conecto mi agente a WhatsApp?</p>
            <span class="meta">9:14 p.m.</span>
          </div>

          <!-- typing y respuesta comparten el mismo lugar -->
          <div class="swap">
            <div class="msg typing">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            </div>

            <div class="msg out">
              <p>Comparteme una captura y lo vemos.</p>
              <span class="meta">
                9:15 p.m.
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="10" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m1 6 3 3 6-7M8 9l1 1 6-7"/></svg>
              </span>
            </div>
          </div>
        </div>

        <figcaption>Acompañamiento real, a cualquier hora</figcaption>
      </figure>
    </div>

    <!-- El ciclo semanal -->
    <div class="cycle reveal">
      {cycle.map((item, i) => (
        <>
          <article class="card glass">
            <div class="card-head">
              <span class="card-icon" aria-hidden="true" set:html={item.icon} />
              <span class="step">{item.step}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
          {i < cycle.length - 1 && (
            <span class="arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12h16m0 0-6-6m6 6-6 6" />
              </svg>
            </span>
          )}
        </>
      ))}
    </div>

    <p class="cycle-caption reveal">
      <svg class="loop-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12a9 9 0 1 1-2.6-6.4M21 3v6h-6" />
      </svg>
      El ciclo se repite cada semana
    </p>

    <div class="section-cta reveal">
      <a href="/testimonios" class="btn btn-primary">Ver testimonios →</a>
    </div>
  </div>
</section>

<style>
  /* estilos de cómo funciona */
  /* ---------- Ciclo ---------- */
  .cycle {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: 12px;
    margin-top: 48px;
  }

  .card {
    border-radius: var(--radius);
    padding: 28px;
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease);
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgb(6 182 212 / 0.5);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .card-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgb(37 99 235 / 0.1), rgb(139 92 246 / 0.1));
    color: var(--accent-blue);
  }

  :global([data-theme='dark']) .card-icon {
    color: var(--accent-cyan);
  }

  .step {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-soft);
    opacity: 0.6;
  }

  .card h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .card p {
    font-size: 0.95rem;
  }

  .arrow {
    display: grid;
    place-items: center;
    color: var(--accent-cyan);
    animation: arrow-nudge 1.8s var(--ease) infinite;
  }

  @keyframes arrow-nudge {
    0%, 100% { transform: translateX(0); opacity: 0.7; }
    50% { transform: translateX(5px); opacity: 1; }
  }

  .cycle-caption {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .loop-icon {
    color: var(--accent-cyan);
    animation: loop-spin 6s linear infinite;
  }

  @keyframes loop-spin {
    to { transform: rotate(360deg); }
  }

  /* ---------- Header + badges ---------- */
  .head-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
  }

  /* Chat de WhatsApp */
  .wa-chat {
    margin: 0;
    justify-self: end;
    width: 100%;
    max-width: 360px;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .wa-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 18px 16px 14px;
    min-height: 150px;
  }

  /* typing y respuesta ocupan la misma celda */
  .swap {
    display: grid;
    justify-items: end;
  }

  .swap > * {
    grid-area: 1 / 1;
  }

  .msg {
    max-width: 85%;
    padding: 9px 13px;
    border-radius: 13px;
    font-size: 0.85rem;
    animation: 9s var(--ease) infinite;
  }

  .msg p {
    color: var(--color-ink);
    font-size: inherit;
  }

  .msg .meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    margin-top: 3px;
    font-size: 0.65rem;
    color: var(--color-ink-soft);
  }

  .msg.in {
    align-self: flex-start;
    border-bottom-left-radius: 4px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    animation-name: msg-in;
  }

  .msg.out {
    align-self: flex-end;
    border-bottom-right-radius: 4px;
    background: rgb(37 211 102 / 0.16);
    border: 1px solid rgb(37 211 102 / 0.3);
    animation-name: msg-out;
  }

  .msg.out .meta svg {
    color: #25d366;
  }

  /* indicador de escribiendo… */
  .msg.typing {
    align-self: flex-end;
    display: flex;
    gap: 4px;
    background: rgb(37 211 102 / 0.16);
    border: 1px solid rgb(37 211 102 / 0.3);
    border-bottom-right-radius: 4px;
    animation-name: msg-typing;
  }

  .typing .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #25d366;
    animation: dot-bounce 1s ease-in-out infinite;
  }

  .typing .dot:nth-child(2) { animation-delay: 0.15s; }
  .typing .dot:nth-child(3) { animation-delay: 0.3s; }

  @keyframes dot-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Ciclo de conversación (9s):
     entra la pregunta → escribiendo… → llega la respuesta → pausa → reinicia */
  @keyframes msg-in {
    0%, 4% { opacity: 0; transform: translateY(8px); }
    9%, 92% { opacity: 1; transform: none; }
    97%, 100% { opacity: 0; transform: translateY(8px); }
  }

  @keyframes msg-typing {
    0%, 14% { opacity: 0; transform: translateY(8px); }
    19%, 44% { opacity: 1; transform: none; }
    49%, 100% { opacity: 0; transform: translateY(8px); position: relative; }
  }

  @keyframes msg-out {
    0%, 49% { opacity: 0; transform: translateY(8px); }
    56%, 92% { opacity: 1; transform: none; }
    97%, 100% { opacity: 0; transform: translateY(8px); }
  }

  .wa-chat figcaption {
    padding: 0 16px 12px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .cycle {
      grid-template-columns: 1fr;
    }

    .arrow {
      padding: 4px 0;
    }

    .arrow svg {
      transform: rotate(90deg);
    }

    @keyframes arrow-nudge {
      0%, 100% { transform: translateY(0); opacity: 0.7; }
      50% { transform: translateY(5px); opacity: 1; }
    }

    .head-row {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .wa-chat {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow,
    .loop-icon,
    .msg,
    .typing .dot {
      animation: none;
    }
    .msg.typing {
      display: none;
    }
  }
</style>
