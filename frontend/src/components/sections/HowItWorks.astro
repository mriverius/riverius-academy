---
// El ciclo semanal — iconos SVG personalizados (sin emojis)
const cycle = [
  {
    step: '01',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4.5" width="19" height="13" rx="3"/><path d="m10 8.5 5 3-5 3z" fill="currentColor" stroke="none"/><path d="M8 21h8"/></svg>`,
    title: 'La clase',
    text: 'Un video nuevo cada semana, disponible cuando quieras. Lo ves a tu ritmo — solo procura verlo antes de tu sesión, para que valga oro.',
  },
  {
    step: '02',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3.5H7a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8.5z"/><path d="M14 3.5v5h5M9 13l2 2 4-4"/></svg>`,
    title: 'Tu tarea',
    text: 'Cada clase termina con algo real que construir. Esa tarea es lo primero que revisamos juntos — nunca se queda sin retroalimentación.',
  },
  {
    step: '03',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8.5" r="3"/><path d="M2.5 19c.8-2.6 2.9-4 5.5-4s4.7 1.4 5.5 4"/><circle cx="17" cy="10" r="2.2"/><path d="M14.5 19c.5-1.9 1.4-2.8 2.5-3 1.9-.4 3.8.9 4.5 3"/></svg>`,
    title: 'Tu sesión en vivo conmigo',
    text: 'Cada semana, tú y yo, nadie más. Me muestras lo que armaste, aclaramos dudas y sales con tu siguiente paso claro.',
  },
];
---

<section id="como-funciona" class="section how has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container">
    <div class="head-row">
      <div class="reveal">
        <p class="eyebrow">Cómo funciona</p>
        <h2 class="section-title">
          Atención personalizada, <span class="gradient-text">a tu ritmo</span>
        </h2>
        <p class="section-intro">
          Nada de cursos grabados que nadie termina. Sigues un ciclo semanal simple, con un
          profesor contigo en cada paso.
        </p>
      </div>

      <div class="badges reveal">
        <div class="badge glass">
          <span class="badge-icon badge-wa" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 11.5a8 8 0 1 1 3.3 3.6L6 17z" />
              <path d="M9 9.5h6M9 12.5h4" />
            </svg>
          </span>
          <span>
            <strong>Acompañamiento por WhatsApp</strong>
            Cualquier duda me la escribes directo, sin esperar tu sesión.
          </span>
        </div>

        <div class="badge glass">
          <span class="badge-icon badge-fire" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2c1 4-4 6-4 10a4 4 0 0 0 8 .5C16 9 13 7 12 2z" />
            </svg>
          </span>
          <span>
            <strong>La racha perfecta</strong>
            Completa cada semana el ciclo y desbloquea el beneficio secreto.
          </span>
        </div>
      </div>
    </div>

    <!-- El ciclo semanal -->
    <div class="cycle reveal">
      {cycle.map((item, i) => (
        <>
          <article class="card glass">
            <div class="card-head">
              <span class="card-icon" aria-hidden="true" set:html={item.icon} />
              <span class="step">{item.step}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
          {i < cycle.length - 1 && (
            <span class="arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12h16m0 0-6-6m6 6-6 6" />
              </svg>
            </span>
          )}
        </>
      ))}
    </div>

    <p class="cycle-caption reveal">
      <svg class="loop-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12a9 9 0 1 1-2.6-6.4M21 3v6h-6" />
      </svg>
      El ciclo se repite cada semana
    </p>

  </div>
</section>

<style>
  /* estilos de cómo funciona */
  /* ---------- Ciclo ---------- */
  .cycle {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: 12px;
    margin-top: 48px;
  }

  .card {
    border-radius: var(--radius);
    padding: 28px;
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease);
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgb(6 182 212 / 0.5);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .card-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgb(37 99 235 / 0.1), rgb(139 92 246 / 0.1));
    color: var(--accent-blue);
  }

  :global([data-theme='dark']) .card-icon {
    color: var(--accent-cyan);
  }

  .step {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-soft);
    opacity: 0.6;
  }

  .card h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .card p {
    font-size: 0.95rem;
  }

  .arrow {
    display: grid;
    place-items: center;
    color: var(--accent-cyan);
    animation: arrow-nudge 1.8s var(--ease) infinite;
  }

  @keyframes arrow-nudge {
    0%, 100% { transform: translateX(0); opacity: 0.7; }
    50% { transform: translateX(5px); opacity: 1; }
  }

  .cycle-caption {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .loop-icon {
    color: var(--accent-cyan);
    animation: loop-spin 6s linear infinite;
  }

  @keyframes loop-spin {
    to { transform: rotate(360deg); }
  }

  /* ---------- Header + badges ---------- */
  .head-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .badges {
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-self: end;
    width: 100%;
    max-width: 400px;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    border-radius: 16px;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease);
  }

  .badge:hover {
    transform: translateY(-2px);
  }

  .badge strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--color-ink);
  }

  .badge-icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
  }

  .badge-wa {
    background: rgb(16 185 129 / 0.12);
    color: #10b981;
  }

  .badge-fire {
    background: linear-gradient(135deg, rgb(250 204 21 / 0.18), rgb(245 158 11 / 0.12));
    color: #f59e0b;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .cycle {
      grid-template-columns: 1fr;
    }

    .arrow {
      padding: 4px 0;
    }

    .arrow svg {
      transform: rotate(90deg);
    }

    @keyframes arrow-nudge {
      0%, 100% { transform: translateY(0); opacity: 0.7; }
      50% { transform: translateY(5px); opacity: 1; }
    }

    .head-row {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .badges {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow,
    .loop-icon {
      animation: none;
    }
  }
</style>
