---
const courses = [
  {
    name: 'Make.com',
    tag: 'Nivel 1 · Principiante',
    color: 'cyan',
    description:
      'Tu punto de partida. Conecta tus aplicaciones favoritas (Gmail, Sheets, CRM…) y deja que la IA haga el trabajo repetitivo. Sin experiencia previa.',
    points: ['Ideal para empezar desde cero', 'Automatiza tareas del día a día', 'Sin instalar nada'],
  },
  {
    name: 'N8N',
    tag: 'Nivel 2 · Intermedio',
    color: 'blue',
    description:
      'El siguiente paso después de Make. Construye agentes de IA de verdad: asistentes que razonan, deciden y ejecutan flujos completos por ti.',
    points: ['Construye agentes autónomos', 'Flujos avanzados con IA', 'Más control y potencia'],
  },
  {
    name: 'Copilot Studio',
    tag: 'Nivel 3 · Avanzado',
    color: 'purple',
    description:
      'El nivel experto. Crea copilotos y chatbots inteligentes integrados con Teams, Outlook y todo el ecosistema Microsoft de tu empresa.',
    points: ['Perfecto para entornos corporativos', 'Integración con Microsoft 365', 'Chatbots para tu equipo'],
  },
];

// Temario semana a semana — edita los temas aquí
const temario = [
  [
    'Fundamentos de la automatización y tu primer escenario',
    'De Make a N8N: nodos, credenciales y flujos',
    'El ecosistema Microsoft 365 y tu primer copiloto',
  ],
  [
    'Conecta Gmail, Sheets y tus apps favoritas',
    'Tu primer agente de IA con memoria',
    'Temas, disparadores y conversaciones',
  ],
  [
    'Filtros, routers y lógica condicional',
    'Herramientas: el agente usa tu correo y calendario',
    'Conocimiento: SharePoint, webs y documentos',
  ],
  [
    'Integra ChatGPT y Claude a tus flujos',
    'RAG: el agente responde con tus documentos',
    'Acciones con Power Automate',
  ],
  [
    'Webhooks y formularios',
    'Multi-agentes y flujos que deciden solos',
    'Tu copiloto dentro de Teams y Outlook',
  ],
  [
    'Manejo de errores y buenas prácticas',
    'Monitoreo, errores y optimización',
    'Seguridad, permisos y gobernanza',
  ],
];

const resultados = [
  'Automatizas tus tareas repetitivas sin escribir código',
  'Construyes agentes de IA autónomos para tu negocio',
  'Despliegas copilotos corporativos en tu empresa',
];
---

<section id="cursos" class="section courses has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container">
    <div class="intro-row">
      <div class="reveal">
        <p class="eyebrow">Nuestros cursos</p>
        <h2 class="section-title">
          Una ruta de aprendizaje, <span class="gradient-text">de cero a experto</span>
        </h2>
        <p class="section-intro">
          Tres cursos que forman una escalera: empiezas sin experiencia con Make.com y avanzas
          hasta construir agentes de IA corporativos. Cada nivel se apoya en el anterior.
        </p>
      </div>

      <!-- Terminal: esto construirás en los cursos -->
      <div class="terminal glass reveal" aria-hidden="true">
        <div class="terminal-bar">
          <span class="tdot tdot-r"></span>
          <span class="tdot tdot-y"></span>
          <span class="tdot tdot-g"></span>
          <span class="terminal-title">mi-agente — riverius</span>
        </div>
        <div class="terminal-body">
          <span class="prompt">&gt;</span>
          <span class="type-target"></span><span class="type-cursor"></span>
          <span class="type-result"></span>
        </div>
      </div>
    </div>

    <div class="grid">
      {courses.map((course) => (
        <article class={`card glass reveal card-${course.color}`}>
          <span class="tag">{course.tag}</span>
          <h3>{course.name}</h3>
          <p class="description">{course.description}</p>
          <ul>
            {course.points.map((point) => <li>{point}</li>)}
          </ul>
          <a href="#inscribete" class="card-link">Más información →</a>
        </article>
      ))}
    </div>

    <!-- Temario semana a semana -->
    <div class="temario-wrap reveal">
      <div class="temario glass" role="table" aria-label="Temario de los cursos">
        <div class="t-row t-head" role="row">
          <span class="t-num t-num-head" role="columnheader">Clases</span>
          <span class="t-cell t-course t-cyan" role="columnheader">Make.com</span>
          <span class="t-cell t-course t-blue" role="columnheader">N8N</span>
          <span class="t-cell t-course t-purple" role="columnheader">Copilot Studio</span>
        </div>

        {temario.map((fila, i) => (
          <div class="t-row" role="row">
            <span class="t-num" role="cell">{String(i + 1).padStart(2, '0')}</span>
            {fila.map((tema) => (
              <span class="t-cell" role="cell">{tema}</span>
            ))}
          </div>
        ))}

        <div class="t-row t-result" role="row">
          <span class="t-num" role="cell" aria-label="Resultado">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          </span>
          {resultados.map((resultado) => (
            <span class="t-cell" role="cell">{resultado}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* estilos de la sección cursos */
  .courses {
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .intro-row {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  /* ---------- Terminal ---------- */
  .terminal {
    width: 100%;
    max-width: 560px;
    justify-self: end;
    border-radius: 14px;
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--glass-border);
  }

  .tdot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.8;
  }

  .tdot-r { background: #f87171; }
  .tdot-y { background: var(--accent-yellow); }
  .tdot-g { background: #34d399; }

  .terminal-title {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-soft);
    opacity: 0.7;
  }

  .terminal-body {
    padding: 14px 16px 16px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink);
    min-height: 64px;
    white-space: nowrap;
    overflow: hidden;
  }

  .prompt {
    color: var(--accent-cyan);
    margin-right: 8px;
  }

  .type-cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent-cyan);
    animation: blink 1s steps(1) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .type-result {
    display: block;
    margin-top: 4px;
    color: #10b981;
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .type-result.show {
    opacity: 1;
  }

  /* ---------- Cards ---------- */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 56px;
  }

  .card {
    display: flex;
    flex-direction: column;
    border-top: 3px solid transparent;
    border-radius: var(--radius);
    padding: 32px 28px;
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }

  .card:hover {
    transform: translateY(-4px);
  }

  .card-cyan { border-top-color: var(--accent-cyan); }
  .card-blue { border-top-color: var(--accent-blue); }
  .card-purple { border-top-color: var(--accent-purple); }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
  }

  .card h3 {
    font-size: 1.5rem;
    margin-block: 10px 12px;
  }

  .description {
    font-size: 0.95rem;
    flex-grow: 1;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 20px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  li {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    padding-left: 24px;
    position: relative;
  }

  li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent-cyan);
    font-weight: 700;
  }

  .card-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--accent-blue);
    transition: opacity 0.2s ease;
  }

  :global([data-theme='dark']) .card-link {
    color: var(--accent-cyan);
  }

  .card-link:hover {
    opacity: 0.75;
  }

  /* ---------- Temario ---------- */
  .temario-wrap {
    margin-top: 32px;
    overflow-x: auto;
    /* deja respirar la sombra del vidrio */
    padding: 4px;
  }

  .temario {
    min-width: 760px;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .t-row {
    display: grid;
    grid-template-columns: 76px 1fr 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .t-row:last-child {
    border-bottom: none;
  }

  .t-head {
    background: rgb(255 255 255 / 0.35);
  }

  :global([data-theme='dark']) .t-head {
    background: rgb(255 255 255 / 0.04);
  }

  .t-course {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .t-course::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .t-cyan::before { background: var(--accent-cyan); }
  .t-blue::before { background: var(--accent-blue); }
  .t-purple::before { background: var(--accent-purple); }

  .t-num {
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    opacity: 0.7;
    border-right: 1px solid var(--color-border);
  }

  .t-num-head {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 1;
    color: var(--color-ink);
    font-weight: 500;
  }

  .t-cell {
    padding: 14px 18px;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
  }

  .t-cell + .t-cell {
    border-left: 1px solid var(--color-border);
  }

  /* fila de resultado */
  .t-result {
    background: linear-gradient(90deg, rgb(6 182 212 / 0.08), rgb(37 99 235 / 0.08), rgb(139 92 246 / 0.08));
  }

  .t-result .t-cell {
    font-weight: 600;
    color: var(--color-ink);
  }

  .t-result .t-num {
    color: var(--accent-cyan);
    opacity: 1;
  }

  @media (max-width: 900px) {
    .intro-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .terminal {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .type-cursor {
      animation: none;
    }
  }
</style>

<script>
  // Typing loop de la terminal
  const target = document.querySelector<HTMLElement>('.type-target');
  const result = document.querySelector<HTMLElement>('.type-result');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const commands = [
    { cmd: 'agente.responder_correos(bandeja)', out: '✓ 12 correos respondidos en 3.1s' },
    { cmd: 'agente.generar_reporte("ventas")', out: '✓ reporte listo y enviado al equipo' },
    { cmd: 'agente.actualizar_crm(nuevos_leads)', out: '✓ 8 contactos sincronizados' },
    { cmd: 'agente.agendar_reuniones(semana)', out: '✓ calendario organizado' },
  ];

  if (target && result) {
    if (reduced) {
      target.textContent = commands[0]!.cmd;
      result.textContent = commands[0]!.out;
      result.classList.add('show');
    } else {
      let i = 0;
      const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

      (async function loop() {
        for (;;) {
          const { cmd, out } = commands[i % commands.length]!;
          result.classList.remove('show');
          result.textContent = '';
          target.textContent = '';

          for (const ch of cmd) {
            target.textContent += ch;
            await sleep(38);
          }
          await sleep(450);
          result.textContent = out;
          result.classList.add('show');
          await sleep(2600);

          while (target.textContent!.length > 0) {
            target.textContent = target.textContent!.slice(0, -1);
            await sleep(12);
          }
          i++;
        }
      })();
    }
  }
</script>
