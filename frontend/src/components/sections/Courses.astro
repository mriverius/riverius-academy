---
/**
 * Versión compacta de la ruta para el homepage:
 * mini camino de nodos + CTA a /cursos (la página completa).
 */
import PathDiagram from '../cursos/PathDiagram.astro';
import PriceBanner from '../cursos/PriceBanner.astro';
---

<section id="cursos" class="section courses has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container">
    <div class="intro-row">
      <div class="reveal">
        <p class="eyebrow">La ruta n8n</p>
        <h2 class="section-title">
          Un camino, <span class="gradient-text">de cero a Arquitecto de Agentes IA</span>
        </h2>
        <p class="section-intro">
          <strong>3 cursos de 6 semanas cada uno</strong>, en orden: cada nivel se apoya en el
          anterior. Al terminar los tres ganas la certificación de
          <strong>Arquitecto de Agentes de IA</strong>, y hay un cuarto
          curso opcional para especializarte. Sin saber programar.
        </p>
      </div>

      <!-- Terminal: esto construirás en los cursos -->
      <div class="terminal glass reveal" aria-hidden="true">
        <div class="terminal-bar">
          <span class="tdot tdot-r"></span>
          <span class="tdot tdot-y"></span>
          <span class="tdot tdot-g"></span>
          <span class="terminal-title">mi-agente — riverius</span>
        </div>
        <div class="terminal-body">
          <span class="prompt">&gt;</span>
          <span class="type-target"></span><span class="type-cursor"></span>
          <span class="type-result"></span>
        </div>
      </div>
    </div>

    <div class="mini-path reveal">
      <PathDiagram compact />
    </div>

    <!-- Precio de lanzamiento -->
    <div class="courses-pricing">
      <PriceBanner />
    </div>

    <div class="section-cta reveal">
      <a href="/cursos" class="btn btn-primary">Ver el camino completo →</a>
    </div>
  </div>
</section>

<style>
  .courses {
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .intro-row {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  /* ---------- Terminal ---------- */
  .terminal {
    width: 100%;
    max-width: 560px;
    justify-self: end;
    border-radius: 14px;
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--glass-border);
  }

  .tdot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.8;
  }

  .tdot-r { background: #f87171; }
  .tdot-y { background: var(--accent-yellow); }
  .tdot-g { background: #34d399; }

  .terminal-title {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-soft);
    opacity: 0.7;
  }

  .terminal-body {
    padding: 14px 16px 16px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink);
    min-height: 64px;
    white-space: nowrap;
    overflow: hidden;
  }

  .prompt {
    color: var(--accent-cyan);
    margin-right: 8px;
  }

  .type-cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent-cyan);
    animation: blink 1s steps(1) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .type-result {
    display: block;
    margin-top: 4px;
    color: #10b981;
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .type-result.show {
    opacity: 1;
  }

  /* ---------- Mini camino ---------- */
  .mini-path {
    margin-top: 56px;
  }

  /* ---------- Precio ---------- */
  .courses-pricing {
    margin-top: 44px;
  }

  @media (max-width: 900px) {
    .intro-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .terminal {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .type-cursor {
      animation: none;
    }
  }
</style>

<script>
  // Typing loop de la terminal
  const target = document.querySelector<HTMLElement>('.type-target');
  const result = document.querySelector<HTMLElement>('.type-result');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const commands = [
    { cmd: 'agente.responder_correos(bandeja)', out: '✓ 12 correos respondidos en 3.1s' },
    { cmd: 'agente.generar_reporte("ventas")', out: '✓ reporte listo y enviado al equipo' },
    { cmd: 'agente.actualizar_crm(nuevos_leads)', out: '✓ 8 contactos sincronizados' },
    { cmd: 'agente.agendar_reuniones(semana)', out: '✓ calendario organizado' },
  ];

  if (target && result) {
    if (reduced) {
      target.textContent = commands[0]!.cmd;
      result.textContent = commands[0]!.out;
      result.classList.add('show');
    } else {
      let i = 0;
      const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

      (async function loop() {
        for (;;) {
          const { cmd, out } = commands[i % commands.length]!;
          result.classList.remove('show');
          result.textContent = '';
          target.textContent = '';

          for (const ch of cmd) {
            target.textContent += ch;
            await sleep(38);
          }
          await sleep(450);
          result.textContent = out;
          result.classList.add('show');
          await sleep(2600);

          while (target.textContent!.length > 0) {
            target.textContent = target.textContent!.slice(0, -1);
            await sleep(12);
          }
          i++;
        }
      })();
    }
  }
</script>
