---
// `count` anima el número; `value` es el texto final
const stats = [
  { value: '+20', count: 20, prefix: '+', label: 'Estudiantes activos' },
  { value: '+2', count: 2, prefix: '+', label: 'Países' },
  { value: '24/7', count: null, prefix: '', label: 'Comunidad disponible' },
];
---

<section id="comunidad" class="section has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container community-inner">
    <div class="reveal">
      <p class="eyebrow">Comunidad</p>
      <h2 class="section-title">
        Rodeado de personas que <span class="gradient-text">también aprenden IA</span>
      </h2>
      <p class="section-intro">
        Contadores, profesores, microbiólogos, periodistas, gente de marketing, ventas,
        finanzas y mucho más: todos aprendiendo a aplicar la IA en su trabajo, igual que tú.
        Comparte tus automatizaciones, resuelve dudas y encuentra inspiración cada día.
      </p>
      <ul class="perks">
        <li>Group calls con toda la comunidad para aprender y conectar</li>
        <li>Canal privado para compartir proyectos y plantillas</li>
      </ul>

      <div class="platforms">
        <span class="platforms-label">La comunidad vive en</span>
        <span class="platform">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="6" width="13" height="12" rx="3" />
            <path d="m15 10 5-3v10l-5-3" />
          </svg>
          Zoom
        </span>
        <span class="platform platform-wa">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
          </svg>
          WhatsApp
        </span>
      </div>
    </div>

    <div class="media reveal">
      <img
        src="/comunidad-980.webp"
        alt="Llamada grupal en vivo de la comunidad de Riverius Academy"
        width="980"
        height="1028"
        loading="lazy"
      />
      <div class="media-stats glass" role="list">
        {stats.map((stat) => (
          <div class="stat" role="listitem">
            <span
              class="stat-value gradient-text"
              data-count={stat.count}
              data-prefix={stat.prefix}
            >
              {stat.value}
            </span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .community-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .perks {
    list-style: none;
    padding: 0;
    margin: 28px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .perks li {
    position: relative;
    padding-left: 30px;
    color: var(--color-ink-soft);
  }

  .perks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 16px;
    height: 16px;
    border-radius: 5px;
    background: var(--gradient-main);
  }

  /* Plataformas de la comunidad */
  .platforms {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .platforms-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    opacity: 0.75;
    margin-right: 4px;
  }

  .platform {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-ink);
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }

  .platform:hover {
    border-color: var(--accent-cyan);
    transform: translateY(-2px);
  }

  .platform svg {
    color: var(--accent-blue);
  }

  .platform-wa svg {
    color: #25d366;
  }

  :global([data-theme='dark']) .platform svg {
    color: var(--accent-cyan);
  }

  /* Foto de la comunidad con stats en vidrio encima */
  .media {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-card-hover);
  }

  .media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .media-stats {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    display: flex;
    justify-content: space-between;
    gap: 8px;
    padding: 14px 20px;
    border-radius: 14px;
    /* más opaco que el vidrio normal: va sobre foto oscura */
    background: var(--glass-bg-strong);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--color-ink-soft);
  }

  @media (max-width: 820px) {
    .community-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<script>
  // Contadores animados al entrar en viewport
  const counters = document.querySelectorAll<HTMLElement>('.stat-value[data-count]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const el = entry.target as HTMLElement;
        observer.unobserve(el);

        const raw = el.dataset.count;
        if (!raw || reduced) continue;
        const end = parseInt(raw, 10);
        const prefix = el.dataset.prefix ?? '';
        const duration = 1200;
        const start = performance.now();

        const tick = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.round(end * eased);
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    },
    { threshold: 0.5 }
  );

  counters.forEach((el) => observer.observe(el));
</script>
