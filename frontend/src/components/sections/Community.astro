---
// `count` anima el número; `value` es el texto final
const stats = [
  { value: '+50', count: 50, prefix: '+', label: 'Estudiantes activos' },
  { value: '+2', count: 2, prefix: '+', label: 'Países' },
  { value: '24/7', count: null, prefix: '', label: 'Comunidad disponible' },
];
---

<section id="comunidad" class="section has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container community-inner">
    <div class="reveal">
      <p class="eyebrow">Comunidad</p>
      <h2 class="section-title">
        Rodeado de personas que <span class="gradient-text">también aprenden IA</span>
      </h2>
      <p class="section-intro">
        Contadores, profesores, microbiólogos, periodistas, gente de marketing, ventas,
        finanzas y mucho más: todos aprendiendo a aplicar la IA en su trabajo, igual que tú.
        Comparte tus automatizaciones, resuelve dudas y encuentra inspiración cada día.
      </p>
      <ul class="perks">
        <li>Group calls con toda la comunidad para aprender y conectar</li>
        <li>Canal privado para compartir proyectos y plantillas</li>
        <li>Retos mensuales con retroalimentación del equipo</li>
      </ul>
    </div>

    <div class="media reveal">
      <img
        src="/comunidad-980.webp"
        alt="Llamada grupal en vivo de la comunidad de Riverius Academy"
        width="980"
        height="1028"
        loading="lazy"
      />
      <div class="media-stats glass" role="list">
        {stats.map((stat) => (
          <div class="stat" role="listitem">
            <span
              class="stat-value gradient-text"
              data-count={stat.count}
              data-prefix={stat.prefix}
            >
              {stat.value}
            </span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .community-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .perks {
    list-style: none;
    padding: 0;
    margin: 28px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .perks li {
    position: relative;
    padding-left: 30px;
    color: var(--color-ink-soft);
  }

  .perks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 16px;
    height: 16px;
    border-radius: 5px;
    background: var(--gradient-main);
  }

  /* Foto de la comunidad con stats en vidrio encima */
  .media {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-card-hover);
  }

  .media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .media-stats {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    display: flex;
    justify-content: space-between;
    gap: 8px;
    padding: 14px 20px;
    border-radius: 14px;
    /* más opaco que el vidrio normal: va sobre foto oscura */
    background: var(--glass-bg-strong);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--color-ink-soft);
  }

  @media (max-width: 820px) {
    .community-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<script>
  // Contadores animados al entrar en viewport
  const counters = document.querySelectorAll<HTMLElement>('.stat-value[data-count]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const el = entry.target as HTMLElement;
        observer.unobserve(el);

        const raw = el.dataset.count;
        if (!raw || reduced) continue;
        const end = parseInt(raw, 10);
        const prefix = el.dataset.prefix ?? '';
        const duration = 1200;
        const start = performance.now();

        const tick = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.round(end * eased);
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    },
    { threshold: 0.5 }
  );

  counters.forEach((el) => observer.observe(el));
</script>
