---
/**
 * Tarjeta detallada de un nivel: promesa, demo en video,
 * "salís con", temario en acordeón, costos y CTA.
 */
import type { Nivel } from '../../data/niveles';
import { waLink } from '../../utils/wa';

interface Props {
  nivel: Nivel;
}

const { nivel } = Astro.props;
---

<article id={nivel.id} class={`level-card glass reveal lc-${nivel.color}`}>
  <span class="lc-ghost" aria-hidden="true">{String(nivel.numero).padStart(2, '0')}</span>

  <header class="lc-head">
    <div>
      <span class="lc-tag">Curso {nivel.numero}{nivel.postCertificacion ? ' · Opcional, después de tu certificación' : ` de 3 · Nivel ${nivel.numero}`}</span>
      <h3 class="lc-name">{nivel.nombre}</h3>
      <p class="lc-promesa">{nivel.promesa}</p>
    </div>
    <span class="lc-duracion">{nivel.duracion}</span>
  </header>

  <div class="lc-body">
    <!-- Demo del curso -->
    <div class="lc-demo">
      {
        nivel.demoVideo ? (
          <iframe
            src={nivel.demoVideo}
            title={`Demo del curso ${nivel.nombre}`}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        ) : (
          <div class="demo-ph" role="img" aria-label={`Demo en video del curso ${nivel.nombre}, próximamente`}>
            <!-- mini-canvas decorativo estilo n8n -->
            <svg class="demo-flow" viewBox="0 0 320 180" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
              <g fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M78 60 C 108 60, 112 90, 142 90" />
                <path d="M178 90 C 208 90, 212 120, 242 120" />
              </g>
              <g fill="currentColor">
                <circle cx="78" cy="60" r="3" />
                <circle cx="142" cy="90" r="3" />
                <circle cx="178" cy="90" r="3" />
                <circle cx="242" cy="120" r="3" />
              </g>
              <g fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="42" y="42" width="36" height="36" rx="9" />
                <rect x="142" y="72" width="36" height="36" rx="9" />
                <rect x="242" y="102" width="36" height="36" rx="9" />
              </g>
            </svg>
            <span class="demo-play" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.5v13l11-6.5-11-6.5z" /></svg>
            </span>
            <span class="demo-label">Demo · {nivel.nombre}</span>
            <span class="demo-soon">Próximamente</span>
          </div>
        )
      }
    </div>

    <div class="lc-main">
      <div class="lc-salis">
        <span class="lc-salis-label">Resultado</span>
        <p>{nivel.salisCon}</p>
      </div>

      <details class="lc-temario">
        <summary>
          Ver el temario del curso
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <ol class="lc-semanas">
          {nivel.semanas.map((semana) => <li>{semana}</li>)}
        </ol>
      </details>

      <p class="lc-incluye">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.5 13 17 22l-5-3-5 3 1.5-9"/></svg>
        {nivel.incluye}
      </p>
    </div>
  </div>

  <footer class="lc-footer">
    <a href={waLink(nivel.waMessage)} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
      Quiero empezar en este nivel
    </a>
    {nivel.reto && (
      <a href="#reto-de-nivel" class="lc-reto">
        ¿Ya sabes n8n? Entra directo con el Reto de Nivel →
      </a>
    )}
  </footer>
</article>

<style>
  .level-card {
    --lc-accent: var(--accent-cyan);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    border-top: 3px solid var(--lc-accent);
    padding: 32px 30px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    scroll-margin-top: 100px;
    transition: box-shadow 0.4s var(--ease), transform 0.4s var(--ease);
  }

  .level-card:hover {
    transform: translateY(-3px);
  }

  /* tinte del color del nivel en la cabecera */
  .level-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 150px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--lc-accent) 10%, transparent), transparent);
    pointer-events: none;
  }

  .lc-blue { --lc-accent: var(--accent-blue); }
  .lc-green { --lc-accent: var(--accent-green); }
  .lc-yellow { --lc-accent: var(--accent-yellow); }
  .lc-purple { --lc-accent: var(--accent-purple); }

  /* highlight al llegar desde el diagrama */
  .level-card.spotlight {
    box-shadow:
      var(--glass-shadow),
      0 0 0 2px var(--lc-accent),
      0 0 40px color-mix(in srgb, var(--lc-accent) 30%, transparent);
  }

  /* número fantasma */
  .lc-ghost {
    position: absolute;
    top: -14px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: 6.5rem;
    font-weight: 700;
    line-height: 1;
    color: color-mix(in srgb, var(--lc-accent) 14%, transparent);
    pointer-events: none;
    user-select: none;
  }

  .lc-head {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .lc-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lc-accent);
  }

  .lc-yellow .lc-tag {
    color: color-mix(in srgb, var(--accent-yellow) 55%, var(--color-ink));
  }

  .lc-name {
    font-size: clamp(1.3rem, 2.4vw, 1.6rem);
    margin-top: 6px;
  }

  .lc-promesa {
    margin-top: 6px;
    font-size: 1rem;
  }

  .lc-duracion {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 4px 12px;
    white-space: nowrap;
    background: var(--color-surface);
  }

  /* ---------- Cuerpo: demo + contenido ---------- */
  .lc-body {
    position: relative;
    display: grid;
    grid-template-columns: minmax(300px, 0.95fr) 1.05fr;
    gap: 26px;
    align-items: start;
  }

  /* ---------- Demo en video ---------- */
  .lc-demo {
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
  }

  .lc-demo iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .demo-ph {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    /* mini-canvas n8n: grid de puntos con tinte del nivel */
    background-image:
      radial-gradient(circle at 65% 30%, color-mix(in srgb, var(--lc-accent) 12%, transparent), transparent 62%),
      radial-gradient(color-mix(in srgb, var(--color-ink) 14%, transparent) 1px, transparent 1px);
    background-size: auto, 16px 16px;
    background-color: var(--color-surface);
    transition: border-color 0.3s ease;
  }

  .level-card:hover .demo-ph {
    border-color: color-mix(in srgb, var(--lc-accent) 60%, var(--color-border));
  }

  .demo-flow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--lc-accent);
    opacity: 0.5;
  }

  .demo-play {
    position: relative;
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    color: #fff;
    background: color-mix(in srgb, var(--lc-accent) 88%, #000);
    box-shadow:
      0 8px 22px color-mix(in srgb, var(--lc-accent) 45%, transparent),
      0 0 0 8px color-mix(in srgb, var(--lc-accent) 12%, transparent);
    transition: transform 0.3s var(--ease);
  }

  .level-card:hover .demo-play {
    transform: scale(1.08);
  }

  .demo-play svg {
    transform: translateX(2px);
  }

  .demo-label {
    position: absolute;
    left: 12px;
    bottom: 12px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--color-ink);
    background: var(--glass-bg-strong);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 5px 12px;
  }

  .demo-soon {
    position: absolute;
    right: 12px;
    top: 12px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    background: var(--glass-bg-strong);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 4px 10px;
  }

  .lc-main {
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-width: 0;
  }

  /* ---------- Salís con (lo más vendedor) ---------- */
  .lc-salis {
    border-left: 3px solid var(--lc-accent);
    background: color-mix(in srgb, var(--lc-accent) 7%, transparent);
    border-radius: 0 12px 12px 0;
    padding: 14px 18px;
  }

  .lc-salis-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-ink);
    display: block;
    margin-bottom: 4px;
  }

  .lc-salis p {
    font-size: 0.98rem;
    color: var(--color-ink);
  }

  /* ---------- Acordeón del temario ---------- */
  .lc-temario {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-surface);
    /* apertura con altura animada (navegadores modernos;
       en el resto abre instantáneo, sin romper nada) */
    interpolate-size: allow-keywords;
  }

  .lc-temario::details-content {
    height: 0;
    overflow: clip;
    transition:
      height 0.45s var(--ease),
      content-visibility 0.45s allow-discrete;
  }

  .lc-temario[open]::details-content {
    height: auto;
  }

  .lc-temario summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 13px 18px;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--color-ink);
    list-style: none;
    user-select: none;
  }

  .lc-temario summary::-webkit-details-marker {
    display: none;
  }

  .lc-temario summary svg {
    transition: transform 0.3s var(--ease);
    color: var(--color-ink-soft);
  }

  .lc-temario[open] summary svg {
    transform: rotate(180deg);
  }

  .lc-semanas {
    list-style: none;
    margin: 0;
    padding: 4px 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 0;
    counter-reset: semana;
  }

  /* las semanas entran en cascada al abrir */
  .lc-temario[open] .lc-semanas li {
    animation: lc-item 0.45s var(--ease) backwards;
  }

  .lc-temario[open] .lc-semanas li:nth-child(1) { animation-delay: 0.06s; }
  .lc-temario[open] .lc-semanas li:nth-child(2) { animation-delay: 0.12s; }
  .lc-temario[open] .lc-semanas li:nth-child(3) { animation-delay: 0.18s; }
  .lc-temario[open] .lc-semanas li:nth-child(4) { animation-delay: 0.24s; }
  .lc-temario[open] .lc-semanas li:nth-child(5) { animation-delay: 0.3s; }
  .lc-temario[open] .lc-semanas li:nth-child(6) { animation-delay: 0.36s; }

  @keyframes lc-item {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
  }

  .lc-semanas li {
    counter-increment: semana;
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding-block: 9px;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    border-bottom: 1px solid var(--color-border);
  }

  .lc-semanas li:last-child {
    border-bottom: none;
  }

  .lc-semanas li::before {
    content: counter(semana, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--lc-accent);
    flex: none;
  }

  .lc-yellow .lc-semanas li::before {
    color: color-mix(in srgb, var(--accent-yellow) 55%, var(--color-ink));
  }

  /* ---------- Incluye (certificado por curso) ---------- */
  .lc-incluye {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-ink-soft);
  }

  .lc-incluye svg {
    color: var(--lc-accent);
    flex: none;
  }

  /* ---------- Footer: CTA + reto ---------- */
  .lc-footer {
    position: relative;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
  }

  .lc-footer .btn {
    font-size: 0.95rem;
    padding: 12px 24px;
  }

  .lc-reto {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--lc-accent);
    transition: opacity 0.2s ease;
  }

  .lc-yellow .lc-reto {
    color: color-mix(in srgb, var(--accent-yellow) 55%, var(--color-ink));
  }

  .lc-reto:hover {
    opacity: 0.75;
  }

  @media (max-width: 760px) {
    .level-card {
      padding: 26px 20px;
    }
    .lc-head {
      flex-direction: column;
    }
    .lc-body {
      grid-template-columns: 1fr;
    }
    .lc-ghost {
      font-size: 5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lc-temario::details-content {
      transition: none;
    }
    .lc-temario[open] .lc-semanas li {
      animation: none;
    }
  }
</style>
