---
/**
 * Sección 4 — La certificación en detalle.
 * Insignia SVG + mockup del certificado hechos en código:
 * siempre coherentes con la marca y respetan dark mode.
 */
import { certificacion } from '../../data/niveles';

/** Iconos dorados de "qué recibes" (paths lucide) */
const recibisIconos = [
  // escudo verificado
  '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  // insignia
  '<circle cx="12" cy="8" r="6"/><path d="M15.5 13 17 22l-5-3-5 3 1.5-9"/>',
  // galería
  '<rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
];
---

<section id="certificacion" class="cert section has-ambient">
  <div class="ambient" aria-hidden="true"></div>
  <div class="container">
    <div class="cert-intro reveal">
      <p class="eyebrow">La meta</p>
      <h2 class="section-title">
        La Certificación: <span class="gold-text">{certificacion.nombre}</span>
      </h2>
      <p class="cert-lema">
        Mientras otros hablan, <span class="lema-strong">nosotros construimos</span>.
      </p>
    </div>

    <!-- Visual protagonista: insignia + mockup del certificado -->
    <div class="cert-visual reveal">
      <div class="badge-wrap" aria-hidden="true">
        <svg class="badge" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="gold-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#fbbf24" />
              <stop offset="55%" stop-color="var(--accent-gold, #d97706)" />
              <stop offset="100%" stop-color="#b45309" />
            </linearGradient>
          </defs>
          <!-- listones -->
          <path d="M44 82 34 112l14-8 8 12 6-22" fill="var(--accent-gold, #d97706)" opacity="0.85" />
          <path d="M76 82l10 30-14-8-8 12-6-22" fill="#b45309" opacity="0.85" />
          <!-- medalla -->
          <circle cx="60" cy="52" r="38" fill="url(#gold-grad)" />
          <circle cx="60" cy="52" r="30" fill="none" stroke="#fff" stroke-opacity="0.55" stroke-width="2" stroke-dasharray="3 4" />
          <!-- robot: agentes de IA -->
          <g stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" fill="none">
            <rect x="46" y="42" width="28" height="22" rx="6" />
            <path d="M60 42v-7m0 0a3.5 3.5 0 1 0-.01 0z" />
            <circle cx="54" cy="52" r="1.6" fill="#fff" />
            <circle cx="66" cy="52" r="1.6" fill="#fff" />
            <path d="M55 58.5h10" />
          </g>
        </svg>
      </div>

      <figure class="cert-mock glass">
        <figcaption class="sr-only">Ejemplo del certificado que recibís</figcaption>
        <div class="cm-head">
          <span class="cm-seal" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 13 17 22l-5-3-5 3 1.5-9"/></svg>
          </span>
          <span class="cm-brand">Riverius Academy</span>
        </div>
        <p class="cm-otorga">Certifica que</p>
        <p class="cm-nombre">Tu Nombre Aquí</p>
        <p class="cm-titulo">es <strong>{certificacion.nombre}</strong></p>
        <p class="cm-detalle">Cursos 1–3 completados · Proyecto final defendido en vivo</p>
        <div class="cm-foot">
          <span class="cm-id">ID {certificacion.idEjemplo}</span>
        </div>
      </figure>
    </div>

    <!-- Qué recibís -->
    <div class="cert-grid">
      {
        certificacion.recibis.map((item, i) => (
          <div class="cert-col glass reveal">
            <span class="cc-top">
              <span class="cc-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={recibisIconos[i]} />
              </span>
              <span class="cc-num">{String(i + 1).padStart(2, '0')}</span>
            </span>
            <h3>{item.titulo}</h3>
            <p>{item.detalle}</p>
            {i === 2 && <a href="/galeria" class="cc-link">Visitar la galería →</a>}
          </div>
        ))
      }
    </div>

    <!-- Cómo se gana: el rigor ES el marketing -->
    <div class="cert-gana glass reveal">
      <h3>Cómo se gana</h3>
      <ol class="gana-steps">
        {
          certificacion.requisitos.map((req, i) => (
            <li class="gana-step">
              <span class="req-num" aria-hidden="true">{i + 1}</span>
              <span class="req-titulo">{req.titulo}</span>
              <span class="req-detalle">{req.detalle}</span>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="section-cta reveal">
      <a href="/verificar" class="btn btn-secondary">Verifica un certificado</a>
    </div>
  </div>
</section>

<style>
  .cert {
    border-block: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  /* ambiente propio: la meta brilla en dorado */
  .cert .ambient {
    background-image:
      radial-gradient(circle 420px at 50% 26%, rgb(217 119 6 / 0.18), transparent 62%),
      radial-gradient(circle 320px at 16% 72%, rgb(251 191 36 / 0.14), transparent 62%),
      radial-gradient(circle 300px at 84% 64%, rgb(139 92 246 / 0.1), transparent 62%);
  }

  .cert-intro {
    text-align: center;
  }

  .cert-intro .section-title {
    margin-inline: auto;
  }

  /* ---------- El lema ---------- */
  .cert-lema {
    margin-top: 20px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.6vw, 1.6rem);
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .lema-strong {
    background: linear-gradient(100deg, var(--accent-gold), #fbbf24, var(--accent-gold));
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradient-flow 6s linear infinite;
  }

  .gold-text {
    background: linear-gradient(100deg, var(--accent-gold), #fbbf24, var(--accent-gold));
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradient-flow 6s linear infinite;
  }

  /* ---------- Visual: insignia + mockup ---------- */
  .cert-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    margin-top: 52px;
  }

  .badge-wrap {
    position: relative;
    flex: none;
    filter: drop-shadow(0 10px 30px var(--gold-glow));
  }

  /* anillos orbitando la insignia */
  .badge-wrap::before,
  .badge-wrap::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 42%;
    border-radius: 50%;
    pointer-events: none;
  }

  .badge-wrap::before {
    width: 118%;
    height: 118%;
    transform: translate(-50%, -50%);
    border: 1.5px dashed color-mix(in srgb, var(--accent-gold) 55%, transparent);
    animation: halo-spin 28s linear infinite;
  }

  .badge-wrap::after {
    width: 148%;
    height: 148%;
    transform: translate(-50%, -50%);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 22%, transparent);
    animation: halo-spin 40s linear infinite reverse;
  }

  @keyframes halo-spin {
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  .badge {
    width: clamp(130px, 16vw, 180px);
    height: auto;
    animation: badge-float 6s ease-in-out infinite;
  }

  @keyframes badge-float {
    50% {
      transform: translateY(-8px);
    }
  }

  .cert-mock {
    position: relative;
    overflow: hidden;
    width: min(440px, 100%);
    border-radius: 16px;
    padding: 28px 32px;
    border-top: 3px solid var(--accent-gold);
    text-align: center;
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }

  .cert-mock:hover {
    transform: translateY(-4px);
    box-shadow:
      var(--glass-shadow),
      0 18px 44px var(--gold-glow);
  }

  /* brillo que barre el certificado cada pocos segundos */
  .cert-mock::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 42%, rgb(255 255 255 / 0.38) 50%, transparent 58%);
    transform: translateX(-130%);
    animation: cert-shine 5.5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes cert-shine {
    0%, 55% {
      transform: translateX(-130%);
    }
    85%, 100% {
      transform: translateX(130%);
    }
  }

  .cm-head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    margin-bottom: 18px;
  }

  .cm-seal {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(135deg, #fbbf24, var(--accent-gold));
    box-shadow: 0 3px 10px var(--gold-glow);
  }

  .cm-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-ink);
  }

  .cm-otorga {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .cm-nombre {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-ink);
    margin-block: 8px 4px;
  }

  .cm-titulo {
    font-size: 0.95rem;
  }

  .cm-titulo strong {
    color: var(--accent-gold);
  }

  .cm-detalle {
    font-size: 0.78rem;
    margin-top: 10px;
    opacity: 0.8;
  }

  .cm-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 22px;
    padding-top: 14px;
    border-top: 1px dashed var(--color-border);
  }

  .cm-id {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent-gold);
    letter-spacing: 0.06em;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  /* ---------- Qué recibís ---------- */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 52px;
  }

  .cert-col {
    border-radius: var(--radius);
    padding: 26px 24px;
    border-top: 3px solid color-mix(in srgb, var(--accent-gold) 65%, transparent);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }

  .cert-col:hover {
    transform: translateY(-4px);
    box-shadow:
      var(--glass-shadow),
      0 14px 34px color-mix(in srgb, var(--accent-gold) 22%, transparent);
  }

  .cc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .cc-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    color: var(--accent-gold);
    background: color-mix(in srgb, var(--accent-gold) 13%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 30%, transparent);
  }

  .cc-num {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--accent-gold) 30%, transparent);
  }

  .cert-col h3 {
    font-size: 1.05rem;
    margin-block: 0 8px;
  }

  .cert-col p {
    font-size: 0.9rem;
  }

  .cc-link {
    display: inline-block;
    margin-top: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--accent-gold);
    transition: opacity 0.2s ease;
  }

  .cc-link:hover {
    opacity: 0.75;
  }

  /* ---------- Cómo se gana ---------- */
  .cert-gana {
    margin-top: 24px;
    border-radius: var(--radius);
    padding: 34px 32px;
    border-top: 3px solid var(--accent-gold);
    text-align: center;
  }

  .cert-gana h3 {
    font-size: 1.15rem;
    margin-bottom: 28px;
  }

  /* ---------- Stepper simétrico de 4 pasos ---------- */
  .gana-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .gana-step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  /* línea que conecta los pasos (solo en fila) */
  .gana-step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 16px;
    left: calc(50% + 28px);
    width: calc(100% - 56px);
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-gold) 50%, transparent) 0 5px,
      transparent 5px 10px
    );
  }

  .req-num {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #fbbf24, var(--accent-gold));
    box-shadow:
      0 4px 10px var(--gold-glow),
      0 0 0 5px color-mix(in srgb, var(--accent-gold) 12%, transparent);
  }

  .req-titulo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.94rem;
    color: var(--color-ink);
    margin-top: 4px;
  }

  .req-detalle {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
  }

  @media (max-width: 860px) {
    .gana-steps {
      grid-template-columns: 1fr 1fr;
      gap: 26px 20px;
    }
    /* sin conectores cuando hay salto de fila */
    .gana-step:nth-child(2)::after {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .gana-steps {
      grid-template-columns: 1fr;
    }
    .gana-step::after {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .cert-visual {
      flex-direction: column;
      gap: 34px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-wrap::before,
    .badge-wrap::after,
    .badge,
    .cert-mock::after,
    .lema-strong {
      animation: none;
    }
    .cert-mock {
      transform: none;
    }
  }
</style>
