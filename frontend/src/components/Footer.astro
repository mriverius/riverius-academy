---
const year = new Date().getFullYear();

const whatsapp = 'https://wa.me/50685973818?text=' +
  encodeURIComponent('Hola Mariano, vi tu sitio web y tengo una pregunta');

const socials = [
  {
    name: 'Instagram',
    href: 'https://instagram.com/mriverius',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="0.6" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/in/mriverius',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M7 10.5V17M7 7.2v.1M11 17v-3.8c0-1.4 1-2.4 2.4-2.4S16 11.8 16 13.2V17"/></svg>`,
  },
  {
    name: 'YouTube',
    href: 'https://youtube.com/@mriverius',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="5.5" width="19" height="13" rx="4"/><path d="m10.2 9.5 4.6 2.5-4.6 2.5z" fill="currentColor" stroke="none"/></svg>`,
  },
];
---

<footer class="site-footer">
  <div class="footer-glow" aria-hidden="true"></div>

  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo" aria-label="Riverius Academy — inicio">
        <img src="/logo-horizontal-2-min.png" alt="Riverius Academy" class="logo-img" width="180" height="46" />
      </a>
      <p>
        Enseñamos IA aplicada a profesionales sin perfil técnico. Aprende a construir agentes
        y automatizaciones que trabajan por ti.
      </p>

      <div class="socials">
        {socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.name}
            title={social.name}
          >
            <span aria-hidden="true" set:html={social.icon} />
          </a>
        ))}
      </div>
    </div>

    <nav class="footer-col" aria-label="Cursos">
      <h4>Cursos</h4>
      <a href="/#cursos">Automatizaciones IA Make.com</a>
      <a href="/#cursos">Agentes IA N8N</a>
      <a href="/#cursos">Agentes IA Copilot Studio</a>
    </nav>

    <nav class="footer-col" aria-label="Academia">
      <h4>Academia</h4>
      <a href="/#que-hacemos">Qué hacemos</a>
      <a href="/#comunidad">Comunidad</a>
      <a href="/#profesor">Tu profesor</a>
      <a href="/testimonios">Testimonios</a>
      <a href="/cursos">Cursos</a>
      <a href="/galeria">Galería de proyectos</a>
      <a href="/verificar">Verificar certificado</a>
    </nav>

    <div class="footer-col footer-contact">
      <h4>¿Tienes dudas?</h4>
      <p>Escríbeme directo y te respondo personalmente.</p>
      <a href={whatsapp} target="_blank" rel="noopener noreferrer" class="wa-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
        </svg>
        WhatsApp
      </a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} Riverius Academy. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  /* estilos del footer */
  .site-footer {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    padding-top: 64px;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
  }

  /* resplandor decorativo */
  .footer-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle 420px at 8% 110%, rgb(6 182 212 / 0.08), transparent 65%),
      radial-gradient(circle 420px at 92% 110%, rgb(139 92 246 / 0.08), transparent 65%);
  }

  .footer-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 40px;
    padding-bottom: 48px;
  }

  .footer-brand p {
    margin-top: 18px;
    max-width: 320px;
    font-size: 0.95rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
  }

  .logo-img {
    height: 46px;
    width: auto;
  }

  :global([data-theme='dark']) .logo-img {
    filter: invert(1) hue-rotate(195deg) brightness(1.1);
  }

  /* redes */
  .socials {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .socials a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 11px;
    border: 1px solid var(--color-border);
    background: var(--glass-bg);
    color: var(--color-ink-soft);
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }

  .socials a:hover {
    color: var(--accent-cyan);
    border-color: var(--accent-cyan);
    transform: translateY(-2px);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .footer-col h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    margin-bottom: 6px;
  }

  .footer-col a {
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    transition: color 0.2s ease, transform 0.2s var(--ease);
  }

  .footer-col a:hover {
    color: var(--accent-blue);
    transform: translateX(2px);
  }

  :global([data-theme='dark']) .footer-col a:hover {
    color: var(--accent-cyan);
  }

  /* contacto por WhatsApp */
  .footer-contact p {
    font-size: 0.9rem;
  }

  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 6px;
    padding: 12px 22px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    color: #fff !important;
    background: var(--gradient-main);
    background-size: 200% auto;
    box-shadow: 0 8px 24px rgb(37 99 235 / 0.3);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }

  .wa-btn:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 12px 32px rgb(139 92 246 / 0.4);
    color: #fff;
  }

  .footer-bottom {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 20px;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p {
    font-size: 0.85rem;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
